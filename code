import math
import matplotlib.pyplot as plt 
def calculate_trajectory(speed, angle_deg, g=9.8):
    angle_rad=math.radians(angle_deg)
    t_flight=(2*speed*math.sin(angle_rad))/g
    x_points=[]
    y_points=[]
    t=0
    dt=0.001
    while t<=t_flight:
        x=speed*math.cos(angle_rad)*t
        y=speed*math.sin(angle_rad)*t -(0.5*g*t**2)
        x_points.append(x)
        y_points.append(y)
        t += dt

    return x_points,y_points
n=int(input("Enter how many graphs do you want to plot"))
for i in range(n):
 speed = float(input("Enter the value of initial speed"))
 angle_deg=float(input("Enter the projection of projectile in theta"))
 x, y = calculate_trajectory(speed, angle_deg)
 plt.plot(x,y,label=angle_deg)
plt.title("Projectile")
plt.xlabel("Distance")
plt.ylabel("Height")
plt.legend()
plt.grid("True")
plt.annotate()
plt.show()